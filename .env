# Medical Appointment Booking Agent — Environment Config
# ═══════════════════════════════════════════════════════════

APP_NAME="Medical Appointment Booking Agent"
APP_VERSION="1.0.0"
DEBUG=true

# ── Ollama / LLM ────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=llama3.2:latest
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048

# ── Aarogya HMIS API ────────────────────────────────────────
ENVIRONMENT=dev
EXTERNAL_API_BASE_URL_DEV=https://dev-hmis-api.aarogya.one/api/v1
EXTERNAL_API_BASE_URL_PROD=https://beta-hmis.aarogya.one/api/v1
EXTERNAL_API_KEY_DEV=0914f928-0705-48c4-abcc-b34e4b277ee8
EXTERNAL_API_KEY_PROD=
EXTERNAL_API_TIMEOUT=30

# API Endpoints
DOCTORS_AVAILABILITY_ENDPOINT=/doctors/availability
BOOK_APPOINTMENT_ENDPOINT=/appointment/schedule

# Default facility (tara hospital nu ID)
DEFAULT_FACILITY_ID=crmpo1ob0004991hpkvg

# ── FastAPI Server ──────────────────────────────────────────
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000

